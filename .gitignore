.env.*
data/credentials.yml
.streamlit/secrets.toml
.streamlit/secrets.toml.*
.streamlit/state/

# 🗑️ 2. Logs e Temporários (O seu log atual tem 200MB!)
*.log
logs/
*.tmp
*.temp
*.swp
*.swo
.DS_Store
Thumbs.db

# 💾 3. Backups e Ficheiros de Sistema
*.bak
*.bak.*
Backup/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 📊 4. Dados Derivados (Gerados automaticamente)
